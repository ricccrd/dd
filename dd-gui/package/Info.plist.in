<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>         <string>dd-app</string>
  <key>CFBundleIdentifier</key>         <string>com.dd.app</string>
  <key>CFBundleName</key>               <string>dd</string>
  <key>CFBundleDisplayName</key>        <string>dd</string>
  <key>CFBundlePackageType</key>        <string>APPL</string>
  <key>CFBundleShortVersionString</key> <string>@VERSION@</string>
  <key>CFBundleVersion</key>            <string>@VERSION@</string>
  <key>CFBundleIconFile</key>           <string>dd-app.icns</string>
  <key>NSHighResolutionCapable</key>    <true/>
  <key>LSMinimumSystemVersion</key>     <string>12.0</string>
  <key>NSPrincipalClass</key>           <string>NSApplication</string>
  <key>LSApplicationCategoryType</key>  <string>public.app-category.developer-tools</string>
</dict>
</plist>
