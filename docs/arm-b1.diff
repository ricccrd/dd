+    emit32(0xCB000000u | (rn << 16) | (16 << 5) | 16); // sub x16,x16,xRn
+    uint32_t *p_cbslow = (uint32_t *)g_cp;
+    emit32(0); // cbnz x16, Lhash
+    // HIT (x16==0, dead+stashed; x17 untouched/live)
