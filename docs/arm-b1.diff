+        e_stur(17, 31, -24);         // borrow x17 as the 2nd scratch
+        e_adrp_add(16, (uint64_t)&g_vt_hit);
+        e_ldr(17, 16, 0);
+        e_addi(17, 17, 1);
+        e_str(17, 16, 0);
+        e_ldur(17, 31, -24);         // restore x17
+    }
